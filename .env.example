# TravelSphere environment configuration
# Copy this file to .env and replace with actual values

# WeatherAPI.com credentials
WEATHER_API_KEY=your_weather_api_key
WEATHER_API_BASE_URL=http://api.weatherapi.com/v1

# OpenTripMap credentials
OPENTRIPMAP_API_KEY=your_opentripmap_api_key
OPENTRIPMAP_BASE_URL=https://api.opentripmap.com/0.1/en

# RestCountries API
REST_COUNTRIES_BASE_URL=https://api.restcountries.com/countries/v5
REST_COUNTRIES_API_KEY=your_restcountries_api_key

# Application port
APP_PORT=8080